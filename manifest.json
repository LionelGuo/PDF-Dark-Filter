{
  "manifest_version": 3,
  "name": "Edge PDF Eye Protector",
  "version": "1.0",
  "description": "Adjust PDF background color for a better reading experience.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["three.min.js", "vanta.waves.min.js", "pdf-lib.min.js", "content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["paper.jpg"],
      "matches": ["<all_urls>"]
    }
  ]
}
